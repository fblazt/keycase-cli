    "vitest": "^4.0.14"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@opentui/core": "^0.3.1",
    "@opentui/react": "^0.3.1",
    "argon2": "^0.44.0",
    "clipboardy": "^5.3.1",
    "commander": "^15.0.0",
    "react": "^19.2.7",
    "react-devtools-core": "^7.0.1",
    "ws": "^8.21.0",
